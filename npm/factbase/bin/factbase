#!/usr/bin/env node

const { execFileSync } = require("child_process");
const path = require("path");
const os = require("os");

const PLATFORMS = {
  "linux-x64": "@everyonce/factbase-linux-x64",
  "darwin-arm64": "@everyonce/factbase-darwin-arm64",
  "darwin-x64": "@everyonce/factbase-darwin-x64",
  "win32-x64": "@everyonce/factbase-win32-x64",
};

const platform = `${os.platform()}-${os.arch()}`;
const pkg = PLATFORMS[platform];

if (!pkg) {
  console.error(`Unsupported platform: ${platform}`);
  console.error(`Supported: ${Object.keys(PLATFORMS).join(", ")}`);
  process.exit(1);
}

let binPath;
try {
  const pkgDir = path.dirname(require.resolve(`${pkg}/package.json`));
  const ext = os.platform() === "win32" ? ".exe" : "";
  binPath = path.join(pkgDir, `bin`, `factbase${ext}`);
} catch {
  console.error(`Could not find ${pkg}. Your platform (${platform}) may not be supported.`);
  console.error(`Try installing from source: cargo install --path .`);
  process.exit(1);
}

const result = require("child_process").spawnSync(binPath, process.argv.slice(2), {
  stdio: "inherit",
});

process.exit(result.status ?? 1);
